<resources>
    <style name="Theme.POSBilling" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/brand</item>
        <item name="android:windowBackground">@color/window_bg</item>
    </style>

    <!--
      Theme for the image cropper (CropImageActivity). It needs an AppCompat theme,
      and its toolbar/confirm-crop menu icon must be visible: a brand-coloured bar
      with white title + white icons so the "done" (crop) button shows clearly.
    -->
    <style name="Theme.Cropper" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorPrimaryVariant">@color/brand</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorAccent">@color/brand</item>
        <item name="colorControlNormal">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="actionMenuTextColor">#FFFFFF</item>
        <item name="android:actionMenuTextColor">#FFFFFF</item>
    </style>
</resources>
